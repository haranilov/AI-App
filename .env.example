# Бесплатные AI (опционально, любой один ключ). Без ключей работает Puter + шаблоны.

# Google Gemini — бесплатно: https://aistudio.google.com/apikey
NEXT_PUBLIC_GEMINI_API_KEY=

# Groq — бесплатно: https://console.groq.com/keys
NEXT_PUBLIC_GROQ_API_KEY=

# Pollinations — бесплатные кредиты: https://enter.pollinations.ai (для браузера ключ pk_)
NEXT_PUBLIC_POLLINATIONS_API_KEY=

# OpenAI (платный, опционально)
NEXT_PUBLIC_OPENAI_API_KEY=
